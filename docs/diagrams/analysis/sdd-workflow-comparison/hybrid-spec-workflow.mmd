graph TD
    User([User/Agent])
    Constitution[["🏛️ Constitution"]]
    PluginEntry{{"🔌 Plugin Entry\n(plugins/sanctuary-guardian/)"}}
    Orchestrator[["⚙️ WorkflowManager\n(plugins/sanctuary-guardian/)"]]

    User -->|"1. Request:<br/>/sanctuary-learning-loop"| PluginEntry
    
    %% Plugin is the direct entry point (no shim layer)
    PluginEntry -->|"2. invoke plugin script"| Orchestrator
    
    %% Constitution aligned at start
    PluginEntry -->|Align with| Constitution
    
    %% Annotation about the architecture
    PluginEntry -.-|"Pure Plugin Architecture:<br/>No bash shims, no tools/cli.py"| ShimNote["ℹ️ Plugin scripts live in:<br/>plugins/sanctuary-guardian/"]
    
    %% Constitution governs all
    Constitution -.->|"Governs all steps"| Note["ℹ️ Adhered to at every phase:<br/>Spec, Plan, Tasks, Execution"]
    
    %% Python Orchestrator handles enforcement
    PluginEntry -->|3. Invoke| Orchestrator
    
    subgraph Enforcement ["Enforcement Layer (Python - ALL Logic Here)"]
        direction TB
        GitCheck["Git State Check<br/>(clean? detached?)"]
        SpecCheck["Spec Detection<br/>(existing folder?)"]
        BranchCheck["Branch Detection<br/>(existing branch?)"]
        ContextInit["Context Manifest Init"]
        
        GitCheck --> SpecCheck
        SpecCheck --> BranchCheck
        BranchCheck --> ContextInit
    end
    
    Orchestrator --> GitCheck
    
    %% Router determines TYPE of work
    ContextInit -->|4. Determine Type| TypeCheck{Work Type?}
    
    TypeCheck -->|Standard - Learning Loop| Scout[/"Protocol 128<br/>Learning Loop"/]
    TypeCheck -->|Custom/Discovery<br/>New Feature/Problem| CustomFlow[Custom Flow]
    
    %% BOTH tracks create Spec-Plan-Tasks (Unified Tracking)
    subgraph UnifiedTracking ["Unified Tracking: spec → plan → tasks"]
        direction TB
        Spec[spec.md]
        Plan[plan.md]
        Tasks[tasks.md]
        
        Spec -->|Define What & Why| Plan
        Plan -->|Define How| Tasks
    end
    
    Scout -->|Defines Context| Spec
    CustomFlow -->|Manual Draft| Spec
    
    %% Execution: Tasks drive work
    Tasks -->|Execute| Execution{Execution}
    
    %% Standard goes to Learning Ops
    Execution -->|Standard| LearningOps
    
    %% Custom goes to Implementation
    Execution -->|Custom| CustomImpl
    subgraph CustomImpl ["Custom Implementation"]
        Implement[/spec-kitty.implement/]
        ManualCode[Manual Code]
    end
    
    %% Learning goes to Protocol Ops
    subgraph LearningOps ["Track C: Learning Ops (Protocol 128)"]
        Audit[/sanctuary-audit/]
        Seal[/sanctuary-seal/]
        Persist[/sanctuary-persist/]
        Audit --> Seal --> Persist
    end
    
    %% Closure
    LearningOps --> Closure
    CustomImpl --> Closure
    
    subgraph Closure ["Universal Closure"]
        Retro[/sanctuary-retrospective/]
        End[/sanctuary-end/]
        Retro --> End
    end
    
    End --> Done([Done])
    
    %% Interaction Links
    click Scout "https://github.com/richfrem/Project_Sanctuary/blob/main/plugins/guardian-onboarding/resources/protocols/protocol_128_learning_loop.mmd" "View Protocol 128 Diagram"

    %% Styling
    style User fill:#fff,stroke:#333
    style Constitution fill:#ff9999,stroke:#333,stroke-width:3px
    style PluginEntry fill:#4B8BBE,stroke:#333,stroke-width:2px,color:#fff
    style ShimNote fill:#fffacd,stroke:#999,stroke-dasharray:5
    style Orchestrator fill:#306998,stroke:#333,stroke-width:2px,color:#fff
    style Note fill:#fffacd,stroke:#999,stroke-dasharray:5
    style GitCheck fill:#ffe4b5,stroke:#333
    style SpecCheck fill:#ffe4b5,stroke:#333
    style BranchCheck fill:#ffe4b5,stroke:#333
    style ContextInit fill:#ffe4b5,stroke:#333
    style TypeCheck fill:#FFD700,stroke:#333
    style Spec fill:#ADD8E6,stroke:#333
    style Plan fill:#ADD8E6,stroke:#333
    style Tasks fill:#ADD8E6,stroke:#333
    style Scout fill:#90EE90,stroke:#333
    style CustomFlow fill:#87CEEB,stroke:#333
